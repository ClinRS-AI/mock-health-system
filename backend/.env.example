# Example environment configuration for the backend

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development

# Backend URLs
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5176

# Postgres connection string (adjust for your environment)
POSTGRES_CONNECTION_STRING=Host=localhost;Port=5432;Database=baseline_db;Username=baseline_user;Password=baseline_password;Include Error Detail=true

# Shared password for SOAP report endpoint (/soap/report)
SOAP_REPORT_PASSWORD=change-me

# Admin UI and protected admin API routes (Auth settings, Monitoring, Test data)
# When set, admin routes accept X-Admin-Key matching this value or a valid JWT in X-Admin-Session
# (minted via POST /api/v1/admin/sessions with body {"adminKey":"..."}).
# AUTH_SETTINGS_ADMIN_KEY=your-static-admin-secret
#
# HS256 signing material for admin session JWTs (optional). JwtService checks in order:
#   1) ADMIN_SESSION_SIGNING_KEY (env)
#   2) AdminSession__SigningKey (env, binds to appsettings AdminSession:SigningKey)
# If neither is set and AUTH_SETTINGS_ADMIN_KEY is set, a key is derived from the admin key.
# ADMIN_SESSION_SIGNING_KEY=
# AdminSession__SigningKey=
#
# Admin session JWT lifetime in minutes (ASP.NET Core options binding for AdminSession:TtlMinutes).
# Default 30 if unset; see appsettings.json "AdminSession".
# AdminSession__TtlMinutes=45
