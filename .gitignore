# Root
.env
.DS_Store

# Logs
logs/
*.log

# Node / frontend
node_modules/
dist/
*.local

# Editor / OS
.vscode/
.idea/
*.swp
*.lscache

# .NET / backend (build output)
bin/
obj/
**/bin/
**/obj/
backend/**/bin*
backend/**/obj*
.vs/

# Terraform — never commit provider/plugin download cache (can be 100MB+ per provider)
**/.terraform/

# Coverage / test outputs
coverage/
TestResults/
TestResultsFullCoverage/

# Claude Code — personal local settings only
.claude/settings.local.json

# Claude Code — auto-memory (personal session notes, not project docs)
memory/

# .NET — environment-specific appsettings that may contain real secrets
appsettings.Development.json
appsettings.Production.json
appsettings.Staging.json

# Terraform — variable value files and state (may contain real secrets)
*.tfvars
*.tfvars.json
terraform.tfstate
terraform.tfstate.backup

# Certificates and private keys
*.pem
*.key
*.pfx
*.p12
*.cer
*.crt

