# Base URL of the Mock Health System API (no trailing slash). Must match where the backend listens
# (see backend launchSettings / README; local default is often http://localhost:5000).
VITE_API_BASE_URL=http://localhost:5001

# Admin UI: after you sign in on the Admin access tab, the short-lived JWT is kept in sessionStorage.
# No extra frontend env vars are required for admin session auth.
